# ═══════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO — Portfolio Profesional
# ═══════════════════════════════════════════════════════════════
# Copia este archivo como .env.local para desarrollo local:
#   cp .env.example .env.local
#
# Para deploy en Dokploy, configura estas variables en el panel
# de Environment Variables del proyecto.
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# Base de datos PostgreSQL
# En Docker Compose, el host es "db" (nombre del servicio).
# Dokploy generará estos valores automáticamente si usas su
# servicio de base de datos, o puedes definirlos manualmente.
# ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://portfolio_user:portfolio_pgpass2024@db:5432/portfolio_db"
POSTGRES_USER="portfolio_user"
POSTGRES_PASSWORD="portfolio_pgpass2024"
POSTGRES_DB="portfolio_db"

# ───────────────────────────────────────────────────────────────
# Resend — Servicio de email transaccional
# Obtén tu API key en: https://resend.com/api-keys
# ───────────────────────────────────────────────────────────────
RESEND_API_KEY="re_CMct4gUy_23k3W8UeeJ7HYM7tGKbTdEmf"

# ───────────────────────────────────────────────────────────────
# Email de destino — donde recibirás los mensajes del formulario
# ───────────────────────────────────────────────────────────────
CONTACT_EMAIL_TO="jcabadcampos12@gmail.com"

# ───────────────────────────────────────────────────────────────
# Email de origen — debe estar verificado en Resend
# (Resend > Domains > verificar tu dominio primero)
# ───────────────────────────────────────────────────────────────
CONTACT_EMAIL_FROM="contacto@abadgroup.tech"

# ───────────────────────────────────────────────────────────────
# URL pública del sitio (sin trailing slash)
# Se usa para og:image, canonical URL, sitemap, etc.
# ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://perfil.abadgroup.tech"

# ───────────────────────────────────────────────────────────────
# Entorno de ejecución
# ───────────────────────────────────────────────────────────────
NODE_ENV="production"

# Puerto en el host donde expondrá la app (útil si 3000 ya está en uso)
# Cambia antes de `docker compose up` si necesitas otro puerto, por ejemplo 3001
HOST_PORT="3000"
